    "robotsSwitcher": "on",
    "siteUrl": "https://marcolastella.com",
    "sitemapSwitcherAuto": "on",
    "customCookies": {
      "colorText": "#424a4d",
      "colorBg": "#eaeff1",
      "colorButton": "#ffffff",
      "colorLink": "#424a4d",
